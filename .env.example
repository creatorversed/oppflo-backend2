# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# SerpAPI (Google search)
SERPAPI_KEY=your-serpapi-key

# Beehiiv (newsletter)
BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUBLICATION_ID=your-publication-id

# Auth
JWT_SECRET=your-secret-for-signing-magic-links-and-tokens

# Public AI tools (anonymous; rate-limited by IP)
PUBLIC_TOOLS_KEY=your-api-key-for-ai-tools-public-endpoint

# Vercel Cron: secures /api/cron-enrich (Authorization: Bearer <value> or x-cron-secret). Set the same value in Vercel project env.
CRON_SECRET=your-random-secret-for-cron-endpoint

# RSS feed (e.g. IMS job listings)
IMS_RSS_URL=https://example.com/feed.xml
